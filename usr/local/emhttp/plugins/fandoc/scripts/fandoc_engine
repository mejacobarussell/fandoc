#!/bin/bash
# YourDitchDoc's Fan Controller Engine v1.0
# Optimized for Corsair Commander Pro + Unraid Arrays

CONF="/boot/config/plugins/fandoc/fandoc.cfg"
LOG="/var/log/fandoc.log"

# Function to get highest disk temp
get_array_temp() {
    # Grabs the highest temp from all active array disks
    max_t=$(smartctl -n standby -A /dev/sd[a-z] 2>/dev/null | grep -i "Temperature_Celsius" | awk '{print $10}' | sort -rn | head -1)
    echo "${max_t:-0}"
}

# Function to get Corsair Probes (Update hwmon index if needed)
get_corsair_temp() {
    p1=$(cat /sys/class/hwmon/hwmon4/temp1_input 2>/dev/null || echo 0)
    p2=$(cat /sys/class/hwmon/hwmon4/temp2_input 2>/dev/null || echo 0)
    # Convert millidegrees to degrees
    t1=$((p1 / 1000))
    t2=$((p2 / 1000))
    [[ $t1 -gt $t2 ]] && echo "$t1" || echo "$t2"
}

while true; do
    ARRAY_T=$(get_array_temp)
    CORSAIR_T=$(get_corsair_temp)
    
    # Determine the "Master" temperature
    [[ $ARRAY_T -gt $CORSAIR_T ]] && CURRENT_T=$ARRAY_T || CURRENT_T=$CORSAIR_T
    
    # Log the decision-making
    echo "$(date): System Max ${CURRENT_T}C (Array: ${ARRAY_T}C, Corsair: ${CORSAIR_T}C)" >> $LOG
    
    # --- PWM Logic Space ---
    # We will add your custom PWM curve logic here next
    # -----------------------

    sleep 60
done
